{
  "expo": {
    "name": "PharmaFICCT",
    "slug": "sw2_p2_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sw2p2mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Permite a la aplicación reconocer tu voz para buscar productos.",
        "NSMicrophoneUsageDescription": "Permite a la aplicación grabar tu voz para buscar productos."
      },
      "bundleIdentifier": "com.l0nkdev.sw2-p2-mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.l0nkdev.sw2_p2_mobile",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAEOW6D1qBg3Pmy-OmL2kwhsqYoQ3498wo"
        }
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permite a la aplicación grabar tu voz para buscar productos.",
          "speechRecognitionPermission": "Permite a la aplicación reconocer tu voz para buscar productos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite a la aplicación usar la cámara para escanear recetas."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#208AEF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f0b4236-668f-49ab-b19a-fc4417abdad8"
      }
    }
  }
}
